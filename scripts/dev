#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib.sh"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage_for "dev"
  exit 0
fi

module="$(normalize_module "${1:-frontend}")"
shift || true

case "$module" in
  frontend)
    run_package_script "$ROOT_DIR/apps/frontend" dev "$@"
    ;;
  extension)
    run_package_script "$ROOT_DIR/apps/extension" dev "$@"
    ;;
  backend)
    printf '%s\n' "Backend has no standalone dev server yet. Use scripts/dev frontend for the Next.js app shell."
    exit 1
    ;;
  agent-workbench)
    run_package_script "$ROOT_DIR/apps/frontend" dev "$@"
    ;;
  repo)
    printf '%s\n' "Run dev targets in separate terminals:"
    printf '%s\n' "  scripts/dev frontend"
    printf '%s\n' "  scripts/dev extension"
    exit 1
    ;;
esac
