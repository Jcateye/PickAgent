#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib.sh"

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage_for "typecheck"
  exit 0
fi

module="$(normalize_module "${1:-repo}")"
shift || true

case "$module" in
  frontend)
    run_package_script "$ROOT_DIR/apps/frontend" typecheck "$@"
    ;;
  extension)
    run_package_script "$ROOT_DIR/apps/extension" typecheck "$@"
    ;;
  backend)
    run_backend_typecheck
    ;;
  agent-workbench)
    run_backend_typecheck
    run_package_script "$ROOT_DIR/apps/frontend" typecheck "$@"
    ;;
  repo)
    run_backend_typecheck
    run_package_script "$ROOT_DIR/apps/frontend" typecheck "$@"
    run_package_script "$ROOT_DIR/apps/extension" typecheck "$@"
    ;;
esac

printf '%s\n' "scripts/typecheck $module completed."
