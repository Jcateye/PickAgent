#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PRISMA_SCHEMA="$ROOT_DIR/apps/backend/prisma/schema.prisma"

if [[ -f "$PRISMA_SCHEMA" ]]; then
  npx --yes prisma validate --schema "$PRISMA_SCHEMA"
fi

backend_ts_files=()
while IFS= read -r file; do
  backend_ts_files+=("$file")
done < <(find "$ROOT_DIR/apps/backend/src" -type f -name '*.ts' | sort)

if ((${#backend_ts_files[@]})); then
  npx --yes -p typescript tsc \
    --noEmit \
    --strict \
    --module Node16 \
    --moduleResolution node16 \
    --target es2022 \
    "${backend_ts_files[@]}"
fi

printf '%s\n' "scripts/typecheck completed."
