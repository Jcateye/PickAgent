      "nullable": false,
      "writable": false,
      "filterable": true,
      "sortable": true,
      "hasDefault": true
    },
    {
      "name": "session_key",
      "dbType": "varchar(256)",
      "comment": "前端或渠道侧会话键",
      "nullable": false,
      "writable": true,
      "requiredOnCreate": true,
      "filterable": true,
      "sortable": true
    },
    {
      "name": "user_id",
      "dbType": "varchar(128)",
      "comment": "用户 ID",
      "nullable": true,
      "writable": true,
      "filterable": true,
      "sortable": true
    },
    {
      "name": "surface",
      "dbType": "varchar(64)",
      "comment": "来源界面",
      "nullable": false,
      "writable": true,
      "hasDefault": true,
      "filterable": true,
      "sortable": true,
      "example": "console"
    },
    {
      "name": "pi_session_key",
      "dbType": "varchar(256)",
      "comment": "Pi 内部 session key",
      "nullable": true,
      "writable": true,
      "filterable": true,
