    {
      "name": "created_at",
      "dbType": "timestamptz",
      "comment": "创建时间",
      "nullable": false,
      "writable": false,
      "sortable": true,
      "hasDefault": true
    },
    {
      "name": "updated_at",
      "dbType": "timestamptz",
      "comment": "更新时间",
      "nullable": false,
      "writable": false,
      "sortable": true,
      "hasDefault": true
    }
