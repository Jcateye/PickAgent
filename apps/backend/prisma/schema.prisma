  createdBy        String?                @map("created_by") @db.VarChar(128)
  /// 创建时间。
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间。
  updatedAt        DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  activity         Activity?              @relation(fields: [activityId], references: [id], onDelete: SetNull)
  workflowRun      WorkflowRun?           @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  simulationRun    ActivitySimulationRun? @relation(fields: [simulationRunId], references: [id], onDelete: SetNull)
  versions         ReportVersion[]

  @@index([reportType, status], map: "reports_type_status_idx")
  @@index([activityId, createdAt], map: "reports_activity_created_idx")
  @@index([workflowRunId], map: "reports_workflow_run_idx")
  @@map("reports")
}

/// 报告版本，保存报告章节、证据快照和导出产物引用。
model ReportVersion {
  /// 主键。
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 报告 ID。
  reportId            String   @map("report_id") @db.Uuid
  /// 版本号。
  version             Int
  /// 版本状态。
  status              String   @default("draft") @db.VarChar(32)
  /// 报告章节 JSON。
  sectionsJson        Json     @default("[]") @map("sections_json") @db.JsonB
  /// 证据引用 JSON。
  evidenceRefsJson    Json     @default("[]") @map("evidence_refs_json") @db.JsonB
  /// 导出产物 JSON。
  exportArtifactsJson Json     @default("[]") @map("export_artifacts_json") @db.JsonB
  /// 创建人。
  createdBy           String?  @map("created_by") @db.VarChar(128)
  /// 创建时间。
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  report              Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, version], map: "report_versions_report_version_key")
  @@index([reportId, status], map: "report_versions_report_status_idx")
  @@map("report_versions")
}

/// 工作区设置，保存数据 freshness、Review SLA、工具策略等 P0 配置。
model WorkspaceSetting {
  /// 主键。
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 设置命名空间。
  namespace   String   @db.VarChar(64)
  /// 设置键。
  settingKey  String   @map("setting_key") @db.VarChar(96)
  /// 设置值 JSON。
  settingJson Json     @default("{}") @map("setting_json") @db.JsonB
  /// 设置状态。
  status      String   @default("active") @db.VarChar(32)
  /// 更新时间。
  updatedBy   String?  @map("updated_by") @db.VarChar(128)
  /// 创建时间。
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间。
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([namespace, settingKey], map: "workspace_settings_namespace_key")
  @@index([namespace, status], map: "workspace_settings_namespace_status_idx")
  @@map("workspace_settings")
}
