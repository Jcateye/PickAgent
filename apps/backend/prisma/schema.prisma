generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// SKU 长期健康状态。
enum HealthStatus {
  READY
  REPAIRABLE
  RISKY
  BLOCKED

  @@map("health_status")
}

/// 活动上下文准入状态。
enum EligibilityStatus {
  DIRECT_READY
  REPAIRABLE_READY
  MANUAL_REVIEW
  BLOCKED

  @@map("eligibility_status")
}

/// Review 人工审批状态。
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  MODIFIED
  CANCELED

  @@map("review_status")
}

/// 工作流运行状态。
enum WorkflowRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED

  @@map("workflow_run_status")
}

/// 工作流步骤状态。
enum WorkflowStepStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED

  @@map("workflow_step_status")
}

/// Agent 会话状态。
enum AgentSessionStatus {
  ACTIVE
  ARCHIVED
  CANCELED

  @@map("agent_session_status")
}

/// Agent Mission 状态。
enum AgentMissionStatus {
  DRAFT
  PLANNING
  RUNNING
  WAITING_FOR_DATA
  WAITING_FOR_REVIEW
  COMPLETED
  FAILED
  CANCELED

  @@map("agent_mission_status")
}

/// Agent Run 状态。
enum AgentRunStatus {
  IDLE
  QUEUED
  PREPARING_CONTEXT
  RUNNING
  STREAMING
  CALLING_TOOL
  PAUSED
  TIMEOUT
  FAILED
  DONE
  CANCELED

  @@map("agent_run_status")
}

/// Agent 消息角色。
enum AgentMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL

  @@map("agent_message_role")
}

/// Agent 工具调用状态。
enum AgentToolCallStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  BLOCKED_BY_POLICY
  WAITING_FOR_APPROVAL
  CANCELED

  @@map("agent_tool_call_status")
}

/// Agent Review Gate 状态。
enum AgentReviewGateStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
  MODIFIED
  CANCELED

  @@map("agent_review_gate_status")
}

/// 数据连接器，记录插件、平台 API、报表导入等采集来源。
model Connector {
  /// 主键。
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 连接器编码。
  code         String         @unique @db.VarChar(64)
  /// 连接器名称。
  name         String         @db.VarChar(128)
  /// 连接器类型。
  kind         String         @db.VarChar(32)
  /// 电商平台标识。
  platform     String?        @db.VarChar(64)
  /// 连接器配置 JSON。
  configJson   Json           @default("{}") @map("config_json") @db.JsonB
  /// 连接器状态。
  status       String         @default("active") @db.VarChar(32)
  /// 创建时间。
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间。
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  skuSnapshots SkuSnapshot[]
  runs         ConnectorRun[]

  @@map("connectors")
}

/// 长期 SKU 档案主语，承接采集事实、健康结论、活动模拟和 Review。
model SkuProfile {
  /// 主键。
  id                String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 稳定 SKU 业务键，MVP 采用 platform:store_id:external_sku_id。
  canonicalKey      String                     @unique @map("canonical_key") @db.VarChar(256)
  /// 电商平台标识。
  platform          String                     @db.VarChar(64)
  /// 店铺或业务主体 ID。
  storeId           String                     @map("store_id") @db.VarChar(128)
  /// 外部平台 SKU ID。
  externalSkuId     String                     @map("external_sku_id") @db.VarChar(128)
  /// 商品名称。
  productName       String?                    @map("product_name") @db.VarChar(256)
  /// 商品类目。
  category          String?                    @db.VarChar(128)
  /// 品牌。
  brand             String?                    @db.VarChar(128)
  /// SKU 档案状态。
  status            String                     @default("active") @db.VarChar(32)
  /// 创建时间。
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间。
  updatedAt         DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  snapshots         SkuSnapshot[]
  diagnoses         SkuHealthDiagnosis[]
  currentProjection CurrentSkuProjection?
  simulationResults ActivitySimulationResult[]
  reviewItems       ReviewItem[]

  @@unique([platform, storeId, externalSkuId], map: "sku_profiles_platform_store_external_key")
  @@index([platform, storeId], map: "sku_profiles_platform_store_idx")
  @@map("sku_profiles")
}

/// 某次采集得到的 SKU 事实快照。
model SkuSnapshot {
  /// 主键。
  id                      String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// SKU 档案 ID。
  skuProfileId            String                     @map("sku_profile_id") @db.Uuid
  /// 连接器 ID。
  connectorId             String?                    @map("connector_id") @db.Uuid
  /// 来源页面 URL。
  sourceUrl               String?                    @map("source_url") @db.Text
  /// 来源行号。
  rowIndex                Int?                       @map("row_index")
  /// 采集时间。
  collectedAt             DateTime                   @default(now()) @map("collected_at") @db.Timestamptz(6)
  /// 商品名称快照。
  productName             String?                    @map("product_name") @db.VarChar(256)
  /// 商品类目快照。
  category                String?                    @db.VarChar(128)
  /// 近 30 天销量。
  sales30d                Int?                       @map("sales30d")
  /// 好评率，取值范围 0 到 1。
  positiveRate            Decimal?                   @map("positive_rate") @db.Decimal(5, 4)
  /// 可售库存。
  stock                   Int?
  /// 原价。
  originalPrice           Decimal?                   @map("original_price") @db.Decimal(12, 2)
  /// 近 30 天最低价。
  lowestPrice30d          Decimal?                   @map("lowest_price_30d") @db.Decimal(12, 2)
  /// 活动价。
  campaignPrice           Decimal?                   @map("campaign_price") @db.Decimal(12, 2)
  /// 是否已参加品牌日等互斥活动。
  joinedBrandDay          Boolean?                   @map("joined_brand_day")
  /// 证书状态。
  certificateStatus       String?                    @map("certificate_status") @db.VarChar(64)
  /// 原始采集数据。
  rawJson                 Json                       @default("{}") @map("raw_json") @db.JsonB
  /// 标准化后的字段数据。
  normalizedJson          Json                       @default("{}") @map("normalized_json") @db.JsonB
  /// 创建时间。
  createdAt               DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  skuProfile              SkuProfile                 @relation(fields: [skuProfileId], references: [id], onDelete: Cascade)
  connector               Connector?                 @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  diagnoses               SkuHealthDiagnosis[]
  currentAsLatestSnapshot CurrentSkuProjection[]     @relation("CurrentLatestSnapshot")
  simulationResults       ActivitySimulationResult[]
  reviewItems             ReviewItem[]

  @@index([skuProfileId, collectedAt], map: "sku_snapshots_profile_collected_idx")
  @@index([connectorId, collectedAt], map: "sku_snapshots_connector_collected_idx")
  @@map("sku_snapshots")
}

/// SKU 日常健康诊断结论。
model SkuHealthDiagnosis {
  /// 主键。
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// SKU 档案 ID。
  skuProfileId             String                     @map("sku_profile_id") @db.Uuid
  /// 关联采集快照 ID。
  snapshotId               String?                    @map("snapshot_id") @db.Uuid
  /// 长期健康状态。
  healthStatus             HealthStatus               @map("health_status")
  /// 健康分，0 到 100。
  healthScore              Int                        @map("health_score")
  /// 数据质量分，0 到 100。
  dataQualityScore         Int                        @map("data_quality_score")
  /// 问题列表 JSON。
  issuesJson               Json                       @default("[]") @map("issues_json") @db.JsonB
  /// 下一步动作 JSON。
  nextActionsJson          Json                       @default("[]") @map("next_actions_json") @db.JsonB
  /// 证据链 JSON。
  evidenceJson             Json                       @default("[]") @map("evidence_json") @db.JsonB
  /// 诊断时间。
  diagnosedAt              DateTime                   @default(now()) @map("diagnosed_at") @db.Timestamptz(6)
  /// 创建时间。
  createdAt                DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  skuProfile               SkuProfile                 @relation(fields: [skuProfileId], references: [id], onDelete: Cascade)
  snapshot                 SkuSnapshot?               @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  currentAsLatestDiagnosis CurrentSkuProjection[]     @relation("CurrentLatestDiagnosis")
  simulationResults        ActivitySimulationResult[]
  reviewItems              ReviewItem[]

  @@index([skuProfileId, diagnosedAt], map: "sku_health_diagnoses_profile_diagnosed_idx")
  @@map("sku_health_diagnoses")
}

/// SKU 当前状态读模型，供 Dashboard、SKU List、Chat summary 和 Report summary 查询。
model CurrentSkuProjection {
  /// SKU 档案 ID，同时作为主键。
  skuProfileId      String              @id @map("sku_profile_id") @db.Uuid
  /// 最新采集快照 ID。
  latestSnapshotId  String?             @map("latest_snapshot_id") @db.Uuid
  /// 最新健康诊断 ID。
  latestDiagnosisId String?             @map("latest_diagnosis_id") @db.Uuid
  /// 当前长期健康状态。
  healthStatus      HealthStatus        @map("health_status")
  /// 当前健康分，0 到 100。
  healthScore       Int                 @map("health_score")
  /// 当前数据质量分，0 到 100。
  dataQualityScore  Int                 @map("data_quality_score")
  /// 顶部问题摘要 JSON。
  topIssuesJson     Json                @default("[]") @map("top_issues_json") @db.JsonB
  /// 创建时间。
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间。
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  skuProfile        SkuProfile          @relation(fields: [skuProfileId], references: [id], onDelete: Cascade)
  latestSnapshot    SkuSnapshot?        @relation("CurrentLatestSnapshot", fields: [latestSnapshotId], references: [id], onDelete: SetNull)
  latestDiagnosis   SkuHealthDiagnosis? @relation("CurrentLatestDiagnosis", fields: [latestDiagnosisId], references: [id], onDelete: SetNull)

  @@index([healthStatus, dataQualityScore], map: "current_sku_projections_health_dq_idx")
  @@map("current_sku_projections")
}

/// 活动规则集，保存规则原文、Rule DSL 和解析元数据。
model ActivityRuleSet {
  /// 主键。
  id                String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 活动规则集名称。
  name              String                     @db.VarChar(160)
  /// 适用平台。
  platform          String?                    @db.VarChar(64)
  /// 规则原文。
  sourceText        String                     @map("source_text") @db.Text
  /// Canonical Rule DSL JSON。
  rulesJson         Json                       @default("[]") @map("rules_json") @db.JsonB
  /// 规则解析模型。
  parseModel        String?                    @map("parse_model") @db.VarChar(128)
  /// 规则解析置信度，取值范围 0 到 1。
  parseConfidence   Decimal?                   @map("parse_confidence") @db.Decimal(5, 4)
  /// 规则解析状态。
  parseStatus       String                     @default("parsed") @map("parse_status") @db.VarChar(32)
  /// 规则解析元数据 JSON。
  parseMetadataJson Json                       @default("{}") @map("parse_metadata_json") @db.JsonB
  /// 创建人。
  createdBy         String?                    @map("created_by") @db.VarChar(128)
  /// 创建时间。
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间。
  updatedAt         DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  activities        Activity[]
  versions          RuleSetVersion[]
  simulationRuns    ActivitySimulationRun[]
  simulationResults ActivitySimulationResult[]
  reviewItems       ReviewItem[]

  @@index([platform, createdAt], map: "activity_rule_sets_platform_created_idx")
  @@map("activity_rule_sets")
}

/// 活动主对象，承载活动名称、范围、状态、时间窗、当前规则集和最新运行引用。
model Activity {
  /// 主键。
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 活动名称。
  name                 String           @db.VarChar(160)
  /// 电商平台标识。
  platform             String?          @db.VarChar(64)
  /// 活动状态。
  status               String           @default("draft") @db.VarChar(32)
  /// 活动范围 JSON。
  scopeJson            Json             @default("{}") @map("scope_json") @db.JsonB
  /// 当前规则集 ID。
  currentRuleSetId     String?          @map("current_rule_set_id") @db.Uuid
  /// 最新工作流运行 ID。
  latestWorkflowRunId  String?          @map("latest_workflow_run_id") @db.Uuid
  /// 活动开始时间。
  startsAt             DateTime?        @map("starts_at") @db.Timestamptz(6)
  /// 活动结束时间。
  endsAt               DateTime?        @map("ends_at") @db.Timestamptz(6)
  /// 活动摘要 JSON。
  summaryJson          Json             @default("{}") @map("summary_json") @db.JsonB
  /// 待确认项 JSON。
  pendingQuestionsJson Json             @default("[]") @map("pending_questions_json") @db.JsonB
  /// 证据引用 JSON。
  evidenceRefsJson     Json             @default("[]") @map("evidence_refs_json") @db.JsonB
  /// 创建人。
  createdBy            String?          @map("created_by") @db.VarChar(128)
  /// 创建时间。
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间。
  updatedAt            DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  currentRuleSet       ActivityRuleSet? @relation(fields: [currentRuleSetId], references: [id], onDelete: SetNull)
  latestWorkflowRun    WorkflowRun?     @relation(fields: [latestWorkflowRunId], references: [id], onDelete: SetNull)
  reports              Report[]

  @@index([platform, status], map: "activities_platform_status_idx")
  @@index([currentRuleSetId], map: "activities_current_rule_set_idx")
  @@index([startsAt, endsAt], map: "activities_time_window_idx")
  @@map("activities")
}

/// 规则库版本，保存规则集历史版本、Rule DSL 快照和发布状态。
model RuleSetVersion {
  /// 主键。
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 活动规则集 ID。
  ruleSetId          String          @map("rule_set_id") @db.Uuid
  /// 版本号。
  version            Int
  /// 版本状态。
  status             String          @default("draft") @db.VarChar(32)
  /// 规则原文快照。
  sourceText         String          @map("source_text") @db.Text
  /// Canonical Rule DSL JSON 快照。
  rulesJson          Json            @default("[]") @map("rules_json") @db.JsonB
  /// 必需字段 JSON。
  requiredFieldsJson Json            @default("[]") @map("required_fields_json") @db.JsonB
  /// 人工确认项 JSON。
  confirmationsJson  Json            @default("[]") @map("confirmations_json") @db.JsonB
  /// 版本元数据 JSON。
  metadataJson       Json            @default("{}") @map("metadata_json") @db.JsonB
  /// 创建人。
  createdBy          String?         @map("created_by") @db.VarChar(128)
  /// 创建时间。
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  ruleSet            ActivityRuleSet @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)

  @@unique([ruleSetId, version], map: "rule_set_versions_rule_version_key")
  @@index([ruleSetId, status], map: "rule_set_versions_rule_status_idx")
  @@map("rule_set_versions")
}

/// 数据源采集运行，记录连接器最近采集运行、行数、质量分、告警和 Workflow 引用。
model ConnectorRun {
  /// 主键。
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 连接器 ID。
  connectorId   String       @map("connector_id") @db.Uuid
  /// 关联工作流运行 ID。
  workflowRunId String?      @map("workflow_run_id") @db.Uuid
  /// 运行状态。
  status        String       @default("pending") @db.VarChar(32)
  /// 采集行数。
  rowCount      Int          @default(0) @map("row_count")
  /// 数据质量分，0 到 100。
  qualityScore  Int?         @map("quality_score")
  /// 告警 JSON。
  warningsJson  Json         @default("[]") @map("warnings_json") @db.JsonB
  /// 运行摘要 JSON。
  summaryJson   Json         @default("{}") @map("summary_json") @db.JsonB
  /// 开始时间。
  startedAt     DateTime?    @map("started_at") @db.Timestamptz(6)
  /// 完成时间。
  completedAt   DateTime?    @map("completed_at") @db.Timestamptz(6)
  /// 创建时间。
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间。
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  connector     Connector    @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  workflowRun   WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@index([connectorId, createdAt], map: "connector_runs_connector_created_idx")
  @@index([status, createdAt], map: "connector_runs_status_created_idx")
  @@map("connector_runs")
}

/// 活动准入模拟运行记录。
model ActivitySimulationRun {
  /// 主键。
  id                String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 活动规则集 ID。
  activityRuleSetId String                     @map("activity_rule_set_id") @db.Uuid
  /// 模拟范围 JSON。
  scopeJson         Json                       @default("{}") @map("scope_json") @db.JsonB
  /// 运行状态。
  status            String                     @default("pending") @db.VarChar(32)
  /// 模拟摘要 JSON。
  summaryJson       Json                       @default("{}") @map("summary_json") @db.JsonB
  /// 运行人。
  runBy             String?                    @map("run_by") @db.VarChar(128)
  /// 开始时间。
  startedAt         DateTime?                  @map("started_at") @db.Timestamptz(6)
  /// 完成时间。
  completedAt       DateTime?                  @map("completed_at") @db.Timestamptz(6)
  /// 创建时间。
  createdAt         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间。
  updatedAt         DateTime                   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  activityRuleSet   ActivityRuleSet            @relation(fields: [activityRuleSetId], references: [id], onDelete: Cascade)
  results           ActivitySimulationResult[]
  reports           Report[]

  @@index([activityRuleSetId, createdAt], map: "activity_simulation_runs_rule_created_idx")
  @@map("activity_simulation_runs")
}

/// 单个 SKU 在某次活动模拟中的准入结论。
model ActivitySimulationResult {
  /// 主键。
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 模拟运行 ID。
  simulationRunId   String                @map("simulation_run_id") @db.Uuid
  /// 活动规则集 ID。
  activityRuleSetId String                @map("activity_rule_set_id") @db.Uuid
  /// SKU 档案 ID。
  skuProfileId      String                @map("sku_profile_id") @db.Uuid
  /// 关联采集快照 ID。
  snapshotId        String?               @map("snapshot_id") @db.Uuid
  /// 关联健康诊断 ID。
  diagnosisId       String?               @map("diagnosis_id") @db.Uuid
  /// 活动上下文准入状态。
  eligibilityStatus EligibilityStatus     @map("eligibility_status")
  /// 准入评分，0 到 100。
  eligibilityScore  Int?                  @map("eligibility_score")
  /// 未通过规则 JSON。
  failedRulesJson   Json                  @default("[]") @map("failed_rules_json") @db.JsonB
  /// 修复计划 JSON。
  repairPlanJson    Json                  @default("[]") @map("repair_plan_json") @db.JsonB
  /// 人工 Review 信息 JSON。
  manualReviewJson  Json                  @default("{}") @map("manual_review_json") @db.JsonB
  /// 证据链 JSON。
  evidenceJson      Json                  @default("[]") @map("evidence_json") @db.JsonB
  /// 创建时间。
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  simulationRun     ActivitySimulationRun @relation(fields: [simulationRunId], references: [id], onDelete: Cascade)
  activityRuleSet   ActivityRuleSet       @relation(fields: [activityRuleSetId], references: [id], onDelete: Cascade)
  skuProfile        SkuProfile            @relation(fields: [skuProfileId], references: [id], onDelete: Cascade)
  snapshot          SkuSnapshot?          @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  diagnosis         SkuHealthDiagnosis?   @relation(fields: [diagnosisId], references: [id], onDelete: SetNull)
  reviewItems       ReviewItem[]

  @@unique([simulationRunId, skuProfileId], map: "activity_simulation_results_run_sku_key")
  @@index([activityRuleSetId, skuProfileId], map: "activity_simulation_results_rule_sku_idx")
  @@index([simulationRunId, eligibilityStatus], map: "activity_simulation_results_run_status_idx")
  @@map("activity_simulation_results")
}

/// 人工 Review 审批任务。
model ReviewItem {
  /// 主键。
  id                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// SKU 档案 ID。
  skuProfileId        String?                   @map("sku_profile_id") @db.Uuid
  /// 采集快照 ID。
  snapshotId          String?                   @map("snapshot_id") @db.Uuid
  /// 健康诊断 ID。
  diagnosisId         String?                   @map("diagnosis_id") @db.Uuid
  /// 活动规则集 ID。
  activityRuleSetId   String?                   @map("activity_rule_set_id") @db.Uuid
  /// 活动模拟结果 ID。
  simulationResultId  String?                   @map("simulation_result_id") @db.Uuid
  /// Review 类型。
  reviewType          String                    @map("review_type") @db.VarChar(64)
  /// Review 原因编码。
  reasonCode          String                    @map("reason_code") @db.VarChar(96)
  /// Review 状态。
  status              ReviewStatus              @default(PENDING)
  /// 需要人工回答的问题。
  question            String                    @db.Text
